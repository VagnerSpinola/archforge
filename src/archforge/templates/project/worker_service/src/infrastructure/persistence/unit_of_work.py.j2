from __future__ import annotations

from application.interfaces.unit_of_work import UnitOfWork
from domain.entities.job import Job
from infrastructure.repositories.in_memory_job_repository import InMemoryJobRepository


class InMemoryUnitOfWork(UnitOfWork):
    def __init__(self) -> None:
        self._jobs = [
            Job(name="reconcile-payments", payload={"batch": "nightly"}),
            Job(name="refresh-analytics", payload={"window": "24h"}),
        ]
        self.jobs = InMemoryJobRepository(self._jobs)

    def __enter__(self) -> "InMemoryUnitOfWork":
        return self

    def __exit__(self, exc_type: object, exc: object, tb: object) -> None:
        if exc is not None:
            self.rollback()

    def commit(self) -> None:
        return None

    def rollback(self) -> None:
        return None