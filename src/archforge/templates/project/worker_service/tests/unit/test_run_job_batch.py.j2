from application.use_cases.run_job_batch import RunJobBatchUseCase
from infrastructure.persistence.unit_of_work import InMemoryUnitOfWork


def test_run_job_batch_marks_jobs_completed() -> None:
    result = RunJobBatchUseCase(unit_of_work=InMemoryUnitOfWork()).execute()

    assert result.processed_jobs == 2
    assert all(status == "completed" for status in result.statuses)